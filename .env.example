# OpenAI API key for email text generation
OPENAI_API_KEY=sk-xxxxx

# Optional override for the email generation model
OPENAI_EMAIL_MODEL=gpt-5.4-nano

# Optional max output tokens for email generation
OPENAI_EMAIL_MAX_OUTPUT_TOKENS=320

# SendGrid API key for email sending
SENDGRID_API_KEY=SG.xxxxx

# Eventbrite API key for event lookup (optional)
EVENTBRITE_API_KEY=xxxxx

# Sender email for SendGrid
SENDER_EMAIL=noreply@eurostarshotels.com
