# ── Gemini / Vertex AI ────────────────────────────────────────────────────
# Ruta al JSON de la service account. Puede ser relativa a la raíz del repo.
GOOGLE_APPLICATION_CREDENTIALS=.secrets/vertex-service-account.json
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1

# Configuración compartida de Gemini para backend batch, chat y sistema autónomo.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
# Permite que Gemini redacte el copy aunque la entrega siga en dry-run.
GEMINI_COPY_IN_DRY_RUN=false

# ── Batch pipeline ────────────────────────────────────────────────────────
CAMPAIGN_MAX_WORKERS=8

# Solo necesario si quieres probar el envío real del pipeline batch.
# El backend sigue usando direcciones placeholder guest_<id>@example.com.
SENDGRID_API_KEY=SG.xxxxx
SENDER_EMAIL=noreply@eurostarshotels.com

# ── Predicción temporal de pre-arrival ────────────────────────────────────
# heuristic   -> comportamiento actual basado en mes habitual + leadtime
# regression  -> predice la próxima fecha de viaje con regresión lineal
TRAVEL_PREDICTION_MODE=heuristic

# En modo regression, el envío se SIMULA con esta antelación.
TRAVEL_REGRESSION_SEND_OFFSET_DAYS=21

# Mínimo de viajes históricos para intentar regresión antes de caer al heurístico.
TRAVEL_REGRESSION_MIN_HISTORY=2

# ── Sistema autónomo ──────────────────────────────────────────────────────
AUTONOMOUS_DRY_RUN=true
AUTONOMOUS_ORACLE_INTERVAL_HOURS=6
AUTONOMOUS_HEARTBEAT_INTERVAL_MINUTES=30
AUTONOMOUS_GENERIC_CAMPAIGN_INTERVAL_HOURS=48
AUTONOMOUS_USER_COOLDOWN_DAYS=14
AUTONOMOUS_SEND_WINDOW_DAYS=7
AUTONOMOUS_MAX_USERS_PER_TICK=25
AUTONOMOUS_MIN_SEGMENT_SIZE_FOR_GENERIC=10

# Compatibilidad con configuraciones antiguas:
# AUTONOMOUS_GEMINI_MODEL=gemini-2.5-flash
# AUTONOMOUS_GEMINI_TEMPERATURE=0.7
